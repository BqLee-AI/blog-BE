# 运行环境，可选 development / production
APP_ENV=development

# 可选：显式指定配置文件路径，支持 yaml / yml / json / env
# APP_CONFIG_FILE=./config.production.json

# 敏感信息建议通过环境变量覆盖，不写入配置文件
DATABASE_PASSWORD=your_secure_password_here
REDIS_PASSWORD=your_secure_redis_password_here
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_mail_password_here

# JWT 配置
# 可以使用文件路径，也可以直接放 PEM 内容（环境变量中的换行可写成 \n）
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=168h

# CORS / 服务级覆盖示例
# SERVER_PORT=8080
# SERVER_MODE=release
# SERVER_TRUSTED_PROXIES=127.0.0.1,::1
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# CORS_ALLOW_CREDENTIALS=false
